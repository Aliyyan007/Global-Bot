# Discord Bot Configuration
discordToken="YOUR_DISCORD_BOT_TOKEN_HERE"

# Primary MongoDB - Core data (profiles, settings, items, etc.)
mongoDB_SRV="mongodb+srv://username:password@cluster.mongodb.net/?appName=YourApp"

# Secondary MongoDB - Logs, analytics, backups
mongoDB_SRV_SECONDARY="mongodb+srv://username:password@cluster.mongodb.net/?appName=YourApp"

# Auto Voice MongoDB - Voice preferences and settings
mongoDB_SRV_AUTOVOICE="mongodb+srv://username:password@cluster.mongodb.net/?appName=YourApp"

# Redis Cache Configuration
# Local: redis://localhost:6379
# Redis Cloud: redis://default:password@host:port
# Upstash: rediss://default:password@host:port
REDIS_URL="redis://localhost:6379"

# Bot Owner ID (Discord User ID)
OWNER_ID="YOUR_DISCORD_USER_ID_HERE"
